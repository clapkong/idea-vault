# ── LLM Models (OpenRouter model IDs) ────────────────────────────────────────
# Orchestrator, Planner, Critic, PRD Writer
# Examples: anthropic/claude-opus-4-5, openai/gpt-4o, google/gemini-pro
MODEL_STRONG=anthropic/claude-sonnet-4-5

# Analyst, Gate
# Examples: anthropic/claude-haiku-4-5, openai/gpt-4o-mini
MODEL_LIGHT=anthropic/claude-haiku-4-5

# ── API Keys ──────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
TAVILY_API_KEY=tvly-...

# ── Loop Limits ───────────────────────────────────────────────────────────────
MAX_OUTER_LOOPS=3
MAX_INNER_LOOPS=3

# ── Mode ──────────────────────────────────────────────────────────────────────
# true: fixtures/ 목업 데이터 사용 (API 키 불필요, UI 개발용)
# false: 실제 에이전트 파이프라인 실행
USE_MOCK_MODE=false
